# URL base del API con sufijo /api. En desarrollo local con proxy de Vite puedes omitir esta línea.
# VITE_API_URL=http://localhost:5000/api
#
# Producción (Vercel): apunta al backend público, ej.:
# VITE_API_URL=https://tu-servicio.onrender.com/api
#
# Open Graph: para redes sociales suele necesitarse URL absoluta en og:image (edita index.html al desplegar).
