# URL base del API con sufijo /api. En desarrollo local con proxy de Vite puedes omitir esta línea.
# VITE_API_URL=http://localhost:5000/api
#
# Producción (Vercel): obligatorio en el proyecto del FRONT (Settings → Environment Variables).
# Si no existe, el build usa /api en el mismo dominio del SPA y los POST suelen devolver 405.
# Ejemplo (sin barra final; el código añade /api si falta):
# VITE_API_URL=https://tu-backend.vercel.app
#
# Open Graph: para redes sociales suele necesitarse URL absoluta en og:image (edita index.html al desplegar).
